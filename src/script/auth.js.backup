// ============================================
// TIMELINK 인증 시스템 - 실제 서버용
// ============================================

const API_BASE_URL = "https://timelink-api.timelink-api.workers.dev";

// 즉시 실행 - DOM 로드 전에 UI 설정
(function initAuthUI() {
    'use strict';
    
    // DOMContentLoaded 이벤트보다 먼저 실행될 수 있도록
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeAuthState);
    } else {
        // 이미 로드된 경우 즉시 실행
        setTimeout(initializeAuthState, 0);
    }
    
    function initializeAuthState() {
        const authElements = document.querySelectorAll('[data-auth-status]');
        if (authElements.length === 0) return;
        
        const token = localStorage.getItem('token');
        const userStr = localStorage.getItem('user');
        
        // 1. 로컬 스토리지 기반으로 즉시 UI 업데이트
        if (token && userStr) {
            try {
                const user = JSON.parse(userStr);
                const balance = user.balance || 10000;
                
                authElements.forEach(el => {
                    // 현재 내용 백업
                    const originalHTML = el.innerHTML;
                    el.setAttribute('data-original-html', originalHTML);
                    
                    // 새로운 내용 설정
                    el.innerHTML = \\님 (\TL)\;
                    el.href = '#';
                    el.style.cssText += '; opacity: 1 !important; visibility: visible !important;';
                    el.setAttribute('data-auth-state', 'logged-in');
                    
                    // 클릭 이벤트
                    el.onclick = function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        performLogout();
                        return false;
                    };
                });
                
                // body에 클래스 추가
                document.body.classList.add('user-logged-in');
                document.body.classList.remove('user-logged-out');
                
            } catch (e) {
                console.error('[Auth] 사용자 데이터 파싱 오류:', e);
                clearAuthData();
            }
        } else {
            // 로그아웃 상태
            authElements.forEach(el => {
                el.innerHTML = '로그인';
                el.href = 'login.html';
                el.style.cssText += '; opacity: 1 !important; visibility: visible !important;';
                el.setAttribute('data-auth-state', 'logged-out');
                el.onclick = null;
            });
            
            document.body.classList.add('user-logged-out');
            document.body.classList.remove('user-logged-in');
        }
        
        // 2. 서버 토큰 검증 (비동기)
        if (token) {
            // 500ms 후에 검증 (UI가 먼저 표시되도록)
            setTimeout(verifyTokenWithServer, 500);
        }
        
        // 초기화 완료 표시
        document.body.setAttribute('data-auth-initialized', 'true');
    }
    
    async function verifyTokenWithServer() {
        const token = localStorage.getItem('token');
        if (!token) return;
        
        try {
            const response = await fetch(\\/api/auth/verify\, {
                method: 'POST',
                headers: {
                    'Authorization': \Bearer \\,
                    'Content-Type': 'application/json'
                }
            });
            
            if (!response.ok) {
                console.log('[Auth] 토큰 만료 또는 무효');
                clearAuthData();
                window.location.reload();
            }
        } catch (error) {
            console.warn('[Auth] 토큰 검증 실패 (네트워크):', error);
            // 네트워크 에러는 사용자 경험을 위해 무시
        }
    }
    
    function clearAuthData() {
        localStorage.removeItem('token');
        localStorage.removeItem('user');
    }
    
    function performLogout() {
        clearAuthData();
        window.location.href = 'index.html';
    }
})();

// ============================================
// 기존 API 함수들
// ============================================

// 이메일 인증
async function verifyEmail(email, verificationCode) {
    try {
        const response = await fetch(API_BASE_URL + '/api/auth/verify', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                email: email,
                verificationCode: verificationCode
            })
        });

        const data = await response.json();
        return data;
    } catch (error) {
        console.error('이메일 인증 오류:', error);
        return { success: false, error: '서버 연결 실패' };
    }
}

// 로그인 함수
async function loginUser(email, password) {
    try {
        const response = await fetch(API_BASE_URL + '/api/auth/login', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                email: email,
                password: password
            })
        });

        const data = await response.json();

        if (data.success) {
            // 토큰 저장
            localStorage.setItem('token', data.token);
            localStorage.setItem('user', JSON.stringify(data.user));
            
            // UI 즉시 업데이트
            setTimeout(() => window.location.href = 'index.html', 100);
            
            return { success: true, user: data.user };
        } else {
            return { success: false, error: data.error };
        }
    } catch (error) {
        console.error('로그인 오류:', error);
        return { success: false, error: '서버 연결 실패' };
    }
}

// 회원가입 함수
async function signupUser(email, password, name) {
    try {
        const response = await fetch(API_BASE_URL + '/api/auth/signup', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                email: email,
                password: password,
                name: name
            })
        });

        const data = await response.json();
        return data;
    } catch (error) {
        console.error('회원가입 오류:', error);
        return { success: false, error: '서버 연결 실패' };
    }
}

// 로그아웃 함수 (글로벌에서 호출 가능)
window.logoutUser = function() {
    localStorage.removeItem('token');
    localStorage.removeItem('user');
    window.location.href = 'index.html';
};

// 유틸리티 함수들
window.isLoggedIn = function() {
    return localStorage.getItem('token') !== null;
};

window.getCurrentUser = function() {
    const userStr = localStorage.getItem('user');
    return userStr ? JSON.parse(userStr) : null;
};

// 글로벌 객체
window.auth = {
    loginUser,
    logoutUser,
    signupUser,
    verifyEmail,
    isLoggedIn,
    getCurrentUser
};

console.log('[Auth] Timelink 인증 시스템 로드 완료');
