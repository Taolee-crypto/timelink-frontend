{
  "name": "timelink",
  "version": "1.0.0",
  "description": "TL Platform Frontend",
  "homepage": "https://yourusername.github.io/timelink",
  "scripts": {
    "dev": "live-server .",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss css/*.css -o dist/css/bundle.min.css --env production",
    "build:js": "esbuild js/*.js --bundle --minify --outdir=dist/js",
    "deploy": "npm run build && gh-pages -d dist -b gh-pages",
    "pwa:generate-icons": "pwa-asset-generator assets/images/logo.png dist/icons",
    "test": "jest"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16",
    "cssnano": "^6.0.1",
    "live-server": "^1.2.2",
    "gh-pages": "^5.0.0",
    "jest": "^29.7.0",
    "pwa-asset-generator": "^6.3.1"
  }
}
