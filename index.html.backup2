<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TL Platform - Time-Based Content Economy</title>
    <script src="js/language.js"></script>
    <link rel="icon" href="favicon.svg" type="image/svg+xml">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a237e 0%, #303f9f 100%);
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 20px;
        }
        .container {
            max-width: 900px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            padding: 50px;
            border-radius: 25px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }
        h1 { 
            font-size: 3.5rem; 
            margin-bottom: 20px; 
            font-weight: 800;
            background: linear-gradient(45deg, #fff, #80deea);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .logo {
            font-size: 5rem;
            margin-bottom: 20px;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        p { 
            font-size: 1.3rem; 
            margin-bottom: 40px; 
            line-height: 1.8;
            opacity: 0.9;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 18px 35px;
            background: linear-gradient(45deg, #2196F3, #1976D2);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1.2rem;
            margin: 15px;
            transition: all 0.3s;
            border: none;
            cursor: pointer;
            min-width: 200px;
        }
        .btn:hover { 
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 10px 30px rgba(33, 150, 243, 0.4);
        }
        .btn-success { 
            background: linear-gradient(45deg, #4CAF50, #388E3C);
        }
        .btn-success:hover {
            box-shadow: 0 10px 30px rgba(76, 175, 80, 0.4);
        }
        .status-panel {
            margin-top: 50px;
            padding: 25px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 15px;
            border-left: 5px solid #4CAF50;
        }
        .status-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .status-item:last-child {
            border-bottom: none;
        }
        .status-label {
            font-weight: 600;
        }
        .status-value {
            font-family: monospace;
            padding: 5px 15px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            font-size: 0.9rem;
        }
        .status-value.online {
            color: #4CAF50;
            background: rgba(76, 175, 80, 0.1);
        }
        .status-value.offline {
            color: #f44336;
            background: rgba(244, 67, 54, 0.1);
        }
        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 40px 0;
        }
        .feature-card {
            background: rgba(255, 255, 255, 0.05);
            padding: 25px;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s;
        }
        .feature-card:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-5px);
        }
        .feature-icon {
            font-size: 2.5rem;
            margin-bottom: 15px;
        }
        .feature-card h3 {
            margin-bottom: 10px;
            color: #80deea;
        }
        .demo-account {
            background: rgba(255, 255, 255, 0.05);
            padding: 20px;
            border-radius: 10px;
            margin: 20px 0;
            text-align: left;
        }
        .demo-account h4 {
            color: #FFC107;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">⚡</div>
        <h1>TL Platform</h1>
        <p>시간 기반 콘텐츠 경제 시스템<br>창작자와 소비자를 연결하는 완벽한 생태계</p>
        
        <div class="demo-account">
            <h4>🎮 데모 계정</h4>
            <p><strong>이메일:</strong> demo@timelink.com</p>
            <p><strong>비밀번호:</strong> demo1234</p>
            <p><strong>보유 TL:</strong> 10,000 TL</p>
        </div>
        
        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-icon">🎵</div>
                <h3>TL Studio</h3>
                <p>고급 콘텐츠 편집 및 변환</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🛒</div>
                <h3>TL 마켓</h3>
                <p>콘텐츠 거래 플랫폼</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🎬</div>
                <h3 data-i18n="tube">TL 튜브</h3>
                <p>비디오 스트리밍 서비스</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">💰</div>
                <h3>공정한 수익</h3>
                <p>55:45 수익 분배 시스템</p>
            </div>
        </div>
        
        <div style="margin: 40px 0;">
            <button class="btn" onclick="startApp()">
                <span>🚀 애플리케이션 시작하기</span>
            </button>
            <button class="btn btn-success" onclick="checkSystemStatus()">
                <span>🔍 시스템 상태 확인</span>
            </button>
        </div>
        
        <div class="status-panel">
            <h3 style="text-align: left; margin-bottom: 20px;">시스템 상태</h3>
            <div class="status-item">
                <span class="status-label">프론트엔드</span>
                <span class="status-value online" id="frontendStatus">확인 중...</span>
            </div>
            <div class="status-item">
                <span class="status-label">백엔드 API</span>
                <span class="status-value" id="backendStatus">확인 중...</span>
            </div>
            <div class="status-item">
                <span class="status-label">데모 모드</span>
                <span class="status-value online">활성화됨 (10,000 TL)</span>
            </div>
            <div class="status-item">
                <span class="status-label">최종 업데이트</span>
                <span class="status-value" id="updateTime">-</span>
            </div>
        </div>
        
        <div style="margin-top: 40px; font-size: 0.9rem; opacity: 0.7;">
            <p>© 2024 TL Platform. timelink.digital</p>
            <p style="margin-top: 10px; font-size: 0.8rem;">
                <span id="apiUrlDisplay">API URL: 로딩 중...</span>
            </p>
        </div>
    </div>
    
    <script src="js/config.js"></script>
    <script src="js/language.js"></script>
<script src="js/language.js"></script>
<script>
// TL Platform 초기화
document.addEventListener("DOMContentLoaded", async function() {
    console.log("🚀 TL Platform 초기화 시작...");
    
    // 언어 설정 적용
    const savedLang = localStorage.getItem("tl_language") || "ko";
    if (typeof applyLanguage === "function") {
        applyLanguage(savedLang);
    } else {
        console.warn("applyLanguage 함수를 찾을 수 없음");
        // 기본 언어 설정만 저장
        localStorage.setItem("tl_language", savedLang);
    }
    
    // API 초기화
    if (typeof TLAPI !== "undefined") {
        const api = await TLAPI.init();
        
        if (api.healthy) {
            console.log("✅ 시스템 정상 작동 중");
            document.body.dataset.connected = "true";
            
            // 기존 토큰 확인
            const token = localStorage.getItem("tl_token");
            if (token) {
                console.log("기존 로그인 토큰 발견");
                // 토큰 검증 로직 추가 가능
            }
        } else {
            console.warn("⚠️ 오프라인 모드");
            document.body.dataset.connected = "false";
            
            // 오프라인 알림
            if (typeof showNotification === "function") {
                showNotification("백엔드 서버에 연결할 수 없습니다. 오프라인 데모 모드로 실행됩니다.", "warning");
            }
        }
    } else {
        console.error("TLAPI가 정의되지 않았습니다.");
    }
});
</script>
</body>
</html>
