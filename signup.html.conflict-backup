                        email: email,
                        nickname: nickname,
                        balance: 10000, // 가입 보너스 10,000 TL
                        joinedAt: new Date().toISOString(),
                        verified: true,
                        marketingAgreed: document.getElementById('marketingAgreement').checked
                    };
                    
                    // 로컬 스토리지에 저장
                    localStorage.setItem('timelink_user', JSON.stringify(userData));
                    localStorage.setItem('timelink_token', 'signup_token_' + Date.now());
                    localStorage.setItem('timelink_userEmail', email);
                    localStorage.setItem('timelink_nickname', nickname);
                    localStorage.setItem('timelink_tlBalance', '10000');
                    
                    console.log('회원가입 완료:', userData);
                    showStatus('회원가입이 완료되었습니다! 10,000 TL이 지급되었습니다.', 'success');
                    
                    // 성공 후 홈페이지로 이동
                    setTimeout(() => {
                        console.log('홈페이지로 이동');
                        window.location.href = 'index.html';
                    }, 1500);
                    
                }, 1500);
            });
            
            // 상태 메시지 표시 함수
            function showStatus(message, type) {
                console.log('상태 메시지:', type, message);
                signupStatus.textContent = message;
                signupStatus.className = 'status-message status-' + type;
                
                // 5초 후 메시지 제거
                setTimeout(() => {
                    signupStatus.className = 'status-message';
                    signupStatus.textContent = '';
                }, 5000);
            }
            
            // 입력 필드 자동 포커스
            document.getElementById('name').focus();
        });
    </script>
</body>
</html>
