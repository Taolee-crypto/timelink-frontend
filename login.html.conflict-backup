                <!-- Account Links -->
                <div class="footer-section">
                    <h4>계정</h4>
                    <div class="footer-links">
                        <a href="login.html"><i class="fas fa-sign-in-alt"></i> 로그인</a>
                        <a href="signup.html"><i class="fas fa-user-plus"></i> 회원가입</a>
                        <a href="dashboard.html"><i class="fas fa-tachometer-alt"></i> 대시보드</a>
