<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TL Platform - Time-Based Content Economy</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #1a237e 0%, #303f9f 100%);
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 20px;
        }
        .container {
            max-width: 800px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 40px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        h1 { font-size: 3rem; margin-bottom: 20px; }
        p { font-size: 1.2rem; margin-bottom: 30px; line-height: 1.6; }
        .btn {
            display: inline-block;
            padding: 15px 30px;
            background: #2196F3;
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: bold;
            margin: 10px;
            transition: all 0.3s;
        }
        .btn:hover { background: #1976D2; transform: translateY(-2px); }
        .btn-success { background: #4CAF50; }
        .btn-success:hover { background: #45a049; }
        .api-status {
            margin-top: 40px;
            padding: 20px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>⚡ TL Platform</h1>
        <p>시간 기반 콘텐츠 경제 시스템 - 완벽한 생태계</p>
        
        <div style="margin: 30px 0;">
            <a href="app.html" class="btn">애플리케이션 시작하기</a>
            <a href="#" class="btn btn-success" onclick="checkAPI()">API 연결 테스트</a>
        </div>
        
        <div class="api-status" id="apiStatus">
            <h3>API 상태 확인 중...</h3>
            <div id="apiResult"></div>
        </div>
    </div>
    
    <script>
        async function checkAPI() {
            const apiUrl = 'https://timelink-api.YOUR_SUBDOMAIN.workers.dev/';
            const resultDiv = document.getElementById('apiResult');
            const statusDiv = document.getElementById('apiStatus');
            
            statusDiv.innerHTML = '<h3>API 연결 테스트 중...</h3>';
            
            try {
                const response = await fetch(apiUrl);
                const data = await response.json();
                
                statusDiv.innerHTML = '<h3>✅ API 연결 성공!</h3>';
                resultDiv.innerHTML = `
                    <p>메시지: ${data.message}</p>
                    <p>상태: ${data.status}</p>
                    <p>버전: ${data.version}</p>
                    <p>시간: ${data.timestamp}</p>
                `;
            } catch (error) {
                statusDiv.innerHTML = '<h3>❌ API 연결 실패</h3>';
                resultDiv.innerHTML = `
                    <p>에러: ${error.message}</p>
                    <p>API URL: ${apiUrl}</p>
                    <p>백엔드 배포가 필요합니다.</p>
                `;
            }
        }
        
        // 페이지 로드 시 API 상태 확인
        window.onload = checkAPI;
    </script>
</body>
</html>
