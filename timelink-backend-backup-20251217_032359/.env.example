# ============================================
# TimeLink 프로덕션 환경 변수 템플릿
# ============================================
# 이 파일을 .env로 복사하고 실제 값을 설정하세요
# ============================================

# 필수: 보안 키들
JWT_SECRET="YOUR_SUPER_SECURE_JWT_SECRET_KEY_HERE"
SENDGRID_API_KEY="SG.YOUR_SENDGRID_API_KEY_HERE"
STRIPE_SECRET_KEY="sk_live_YOUR_STRIPE_SECRET_KEY_HERE"
CLOUDFLARE_API_TOKEN="YOUR_CLOUDFLARE_API_TOKEN_HERE"
CLOUDFLARE_ACCOUNT_ID="YOUR_CLOUDFLARE_ACCOUNT_ID_HERE"

# 필수: 애플리케이션 설정
APP_URL="https://timelink.digital"
EMAIL_FROM="noreply@timelink.digital"
ENVIRONMENT="production"

# 필수: 데이터베이스 (D1)
# D1 데이터베이스 ID는 wrangler.toml에 설정됨

# 필수: 파일 저장 (R2)
# R2 버킷 이름은 wrangler.toml에 설정됨

# 옵션: 파일 업로드 제한
MAX_MUSIC_FILE_SIZE="524288000"      # 500MB
MAX_VIDEO_FILE_SIZE="2147483648"     # 2GB
SUPPORTED_AUDIO_FORMATS="mp3,wav,flac,m4a,aac"
SUPPORTED_VIDEO_FORMATS="mp4,webm,mov,avi"

# 옵션: TL 경제 설정
INITIAL_TL_BALANCE="10000"
TL_CONVERSION_FEE="50"
DEFAULT_TL_FORMAT="tl3"
DEFAULT_VIDEO_QUALITY="1080p"
DEFAULT_MULTIPLIER="1"

# 옵션: 인증 설정
TOKEN_EXPIRY="86400"                 # 24시간
REFRESH_TOKEN_EXPIRY="2592000"       # 30일
PASSWORD_MIN_LENGTH="8"
PASSWORD_REQUIRE_UPPERCASE="true"
PASSWORD_REQUIRE_NUMBER="true"
PASSWORD_REQUIRE_SPECIAL="true"

# 옵션: 결제 설정 (Stripe)
STRIPE_WEBHOOK_SECRET="whsec_YOUR_STRIPE_WEBHOOK_SECRET"
STRIPE_PUBLISHABLE_KEY="pk_live_YOUR_STRIPE_PUBLISHABLE_KEY"

# 옵션: 이메일 설정
EMAIL_SERVICE="sendgrid"             # sendgrid, mailgun, ses
SENDGRID_TEMPLATE_WELCOME="d-1234567890"
SENDGRID_TEMPLATE_RESET="d-0987654321"

# 옵션: 분석 및 모니터링
SENTRY_DSN="https://your-sentry-dsn.ingest.sentry.io/your-project"
GOOGLE_ANALYTICS_ID="UA-XXXXXXXXX-X"
LOG_LEVEL="info"                     # debug, info, warn, error

# 옵션: 캐시 설정
CACHE_TTL_DEFAULT="3600"             # 1시간
CACHE_TTL_METADATA="300"             # 5분
CACHE_TTL_THUMBNAIL="604800"         # 7일

# 옵션: 업로드 설정
ALLOWED_FILE_TYPES="audio/*,video/*,image/jpeg,image/png"
MAX_FILES_PER_USER="1000"
MAX_STORAGE_PER_USER="10737418240"   # 10GB

# 옵션: 웹훅 설정
WEBHOOK_URL_CHARGE="https://your-webhook.com/charge"
WEBHOOK_URL_CONVERSION="https://your-webhook.com/conversion"
WEBHOOK_SECRET="your-webhook-secret"

# 옵션: API 제한
RATE_LIMIT_REQUESTS="100"
RATE_LIMIT_PERIOD="60"               # 초 단위
API_KEY_REQUIRED="false"

# ============================================
# 배포 전 체크리스트:
# 1. 모든 필수 변수가 설정되었는지 확인
# 2. JWT_SECRET은 충분히 복잡하고 안전하게 설정
# 3. Cloudflare API 토큰에 적절한 권한이 있는지 확인
# 4. Stripe 키가 올바른 환경(live/test)인지 확인
# 5. 이메일 설정이 제대로 작동하는지 테스트
# ============================================
