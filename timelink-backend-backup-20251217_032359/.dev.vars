# TimeLink 개발 환경 변수
JWT_SECRET="dev-super-secret-jwt-key-change-in-production"
SENDGRID_API_KEY="SG.dev-key-placeholder"
STRIPE_SECRET_KEY="sk_test_dev_placeholder"
APP_URL="http://localhost:3000"
EMAIL_FROM="dev@timelink.local"

# 파일 업로드 설정
MAX_MUSIC_FILE_SIZE="524288000"      # 500MB
MAX_VIDEO_FILE_SIZE="2147483648"     # 2GB
SUPPORTED_AUDIO_FORMATS="mp3,wav,flac,m4a,aac"
SUPPORTED_VIDEO_FORMATS="mp4,webm,mov,avi"

# TL 설정
INITIAL_TL_BALANCE="10000"
TL_CONVERSION_FEE="50"
DEFAULT_TL_FORMAT="tl3"
DEFAULT_VIDEO_QUALITY="1080p"

# 인증 설정
TOKEN_EXPIRY="86400"                 # 24시간
REFRESH_TOKEN_EXPIRY="2592000"       # 30일

# Cloudflare Workers 설정 (로컬 개발용)
WORKERS_DEV="true"
ENVIRONMENT="development"

# 데이터베이스 연결 (개발용)
# 실제 값은 wrangler.toml에서 설정
